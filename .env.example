# Copy this file to .env and tune as needed.
TRANSLATION_ENGINE=google
GOOGLE_TIMEOUT=30
HYBRID_MAX_SEGMENTS=40
HYBRID_MIN_CHARS=100
HYBRID_MIN_SCORE=2
HYBRID_WORKERS=2
LMSTUDIO_BASE_URL=http://127.0.0.1:1234/v1
LMSTUDIO_MODEL=translategemma-4b-it
LMSTUDIO_TIMEOUT=0
LMSTUDIO_MAX_TOKENS=6144
LMSTUDIO_TEMPERATURE=0.1
LMSTUDIO_MAX_WORKERS=4
LLM_SINGLE_CALL=0
LLM_SINGLE_CALL_MAX_CHARS=70000
LLM_SINGLE_CALL_MIN_BATCH_ITEMS=4
